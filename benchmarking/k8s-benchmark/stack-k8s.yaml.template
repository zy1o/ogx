apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: llama-benchmark-pvc
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 1Gi
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: ogx-benchmark-server
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: ogx-benchmark
      app.kubernetes.io/component: server
  template:
    metadata:
      labels:
        app.kubernetes.io/name: ogx-benchmark
        app.kubernetes.io/component: server
    spec:
      containers:
      - name: ogx-benchmark
        image: ogx/distribution-starter:latest
        imagePullPolicy: Always # since we have specified latest instead of a version
        env:
        - name: ENABLE_CHROMADB
          value: "true"
        - name: CHROMADB_URL
          value: http://chromadb.default.svc.cluster.local:6000
        - name: POSTGRES_HOST
          value: postgres-server.default.svc.cluster.local
        - name: POSTGRES_PORT
          value: "5432"
        - name: INFERENCE_MODEL
          value: "${INFERENCE_MODEL}"
        - name: TAVILY_SEARCH_API_KEY
          value: "${TAVILY_SEARCH_API_KEY}"
        - name: VLLM_URL
          value: http://vllm-server.default.svc.cluster.local:8000/v1
        - name: VLLM_MAX_TOKENS
          value: "3072"
        - name: VLLM_TLS_VERIFY
          value: "false"
        - name: OGX_LOGGING
          value: "all=WARNING"
        - name: OGX_CONFIG
          value: "/etc/config/stack_run_config.yaml"
        - name: OGX_WORKERS
          value: "${OGX_WORKERS}"
        command: ["uvicorn", "ogx.core.server.server:create_app", "--host", "0.0.0.0", "--port", "8323", "--workers", "$(OGX_WORKERS)", "--factory"]
        ports:
          - containerPort: 8323
        resources:
          requests:
            cpu: "4"
          limits:
            cpu: "4"
        volumeMounts:
          - name: llama-storage
            mountPath: /root/.llama
          - name: llama-config
            mountPath: /etc/config
      volumes:
      - name: llama-storage
        persistentVolumeClaim:
          claimName: llama-benchmark-pvc
      - name: llama-config
        configMap:
          name: ogx-config
---
apiVersion: v1
kind: Service
metadata:
  name: ogx-benchmark-service
spec:
  selector:
    app.kubernetes.io/name: ogx-benchmark
    app.kubernetes.io/component: server
  ports:
  - name: http
    port: 8323
    targetPort: 8323
  type: ClusterIP
